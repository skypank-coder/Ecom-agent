# =================================
# EcomAgent Environment Variables
# =================================

# Groq AI API Key
# Get free at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Shopify Store Configuration
# Your store URL (without https://)
SHOPIFY_STORE_URL=your-store-name.myshopify.com

# Shopify Admin API Access Token
# Get from: Settings -> Apps -> Develop Apps
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxx

# Default Supplier URL for CLI usage
# Change this to any product page URL
SUPPLIER_URL=https://books.toscrape.com/catalogue/a-light-in-the-attic_1000/index.html